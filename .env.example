# SightLine — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Vision backend ─────────────────────────────────────────────────────────────
# "mock"   = fake responses, no GPU needed (good for front-end dev)
# "ollama" = local Ollama (install separately)
# "vllm"   = AMD Cloud / any OpenAI-compatible vision API
VISION_BACKEND=mock

# vLLM endpoint (when VISION_BACKEND=vllm)
VLLM_BASE_URL=http://localhost:8001/v1

# Ollama endpoint + model (when VISION_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision:11b

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_AGENT_ID=your_agent_id_here
# Default voice is "Bella" — change to any ElevenLabs voice ID
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ── Capture service ────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRAME_INTERVAL=2
